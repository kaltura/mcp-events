{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "lib": ["ES2020"],
    "types": ["node"],
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "apps",
    "esModuleInterop": true,
    "strict": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  },
  "include": ["apps/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
